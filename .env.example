# Environment variables for production deployment

# API Settings
API_URL=https://yourdomain.com/api
FRONTEND_URL=https://yourdomain.com

# Google Drive Model IDs
# REQUIRED for deployment - upload your models to Google Drive and get their sharing IDs
# To get ID: Right-click file → Share → Link → Extract ID from link
# Example: https://drive.google.com/file/d/1ABC2DEF3GHIJ4KLMN5O/view?usp=sharing
# ID = 1ABC2DEF3GHIJ4KLMN5O

# These IDs were already configured - copy to Railway environment variables
GDRIVE_FULL_MODEL_ELA_PKL=1ib2WLtJPfDOQeaWJaJM_HQhM8qeDgeux
GDRIVE_FULL_MODEL_FREQ_PKL=1m15sxulaBU5_YPzCkDp-lHzmZy_6dp7n
GDRIVE_FULL_MODEL_PIXELHYBRID_PKL=1QUHlEKU3lXZ22ZzounKCBnwM3zf4Cc5W
GDRIVE_FULL_MODEL_XCEPTION_PKL=1cxzQYMMwmVzLnuXoTsRsGi12l9e43Dfg

# Optional: Database
DATABASE_URL=


# Optional: Authentication
SECRET_KEY=your_secret_key_here
