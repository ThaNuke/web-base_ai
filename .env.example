# Environment variables for production deployment

# API Settings
API_URL=https://yourdomain.com/api
FRONTEND_URL=https://yourdomain.com

# Google Drive Model IDs
# Upload your models to Google Drive and get their sharing IDs
# To get ID: Right-click file → Share → Link → Extract ID from link
# Example: https://drive.google.com/file/d/1ABC2DEF3GHIJ4KLMN5O/view?usp=sharing
# ID = 1ABC2DEF3GHIJ4KLMN5O

GDRIVE_FULL_MODEL_ELA_PKL=your_google_drive_id_here
GDRIVE_FULL_MODEL_FREQ_PKL=your_google_drive_id_here
GDRIVE_FULL_MODEL_PIXELHYBRID_PKL=your_google_drive_id_here
GDRIVE_FULL_MODEL_XCEPTION_PKL=your_google_drive_id_here

# Optional: Database
DATABASE_URL=

# Optional: Authentication
SECRET_KEY=your_secret_key_here
